generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

model Product {
  id                  String          @id @default(cuid())

  // ── Product Identity Group (A–J) ──
  sourceRow           Int?            // A: Auto-generated sequential row number
  productId           String?         // B: Globally unique ERP identifier (12 digits)
  sku                 String?         // C: Stock Keeping Unit (12 digits, usually = Product ID)
  ndNumber            String?         // D: Al-Nassim internal number (ND-XXXX format)
  barcode             String?         // E: EAN-13 / UPC-A barcode
  legacyCode          String?         // F: Legacy ERP code (deprecated)
  brand               String?         // G: Brand name EN (controlled list)
  brandAr             String?         // H: Brand name AR (auto-derived from Brand)
  brandCode           String?         // I: 3-digit brand code (auto-derived from Brand)
  model               String?         // J: Manufacturer model/variant code

  // ── Classification Group (K–P) ──
  department          String?         // K: Taxonomy level 1 (controlled list)
  category            String?         // L: Taxonomy level 2 (dependent on Department)
  subcategory         String?         // M: Taxonomy level 3 (dependent on Category)
  sectionCode         String?         // N: 3-digit retail section code (auto-derived from Dept)
  productFamily       String?         // O: Taxonomy level 4 (dependent on Subcategory)
  productType         String?         // P: Taxonomy level 5 (dependent on Product Family)

  // ── Product Information Group (Q–V) ──
  nameAr              String?         // Q: Full product name in Arabic
  nameEn              String?         // R: Full product name in English
  shortDescAr         String?         // S: Short description AR (defaults to Name AR)
  shortDescEn         String?         // T: Short description EN (defaults to Name EN)
  longDescAr          String?         // U: Long description AR (optional)
  longDescEn          String?         // V: Long description EN (auto-generated from Brand + Name EN)

  // ── Attributes Group (W–AI) ──
  color               String?         // W: Color EN (controlled list, 15 values)
  colorAr             String?         // X: Color AR (auto-derived from Color)
  material            String?         // Y: Material EN (controlled list, ~15 values)
  materialAr          String?         // Z: Material AR (auto-derived from Material)
  capacity            Float?          // AA: Numeric capacity/volume/weight
  capacityUnit        String?         // AB: L, ml, kg, g
  weight              Float?          // AC: Product weight (decimal)
  weightUnit          String?         // AD: kg, g
  length              Float?          // AE: Length in Dimension Unit
  width               Float?          // AF: Width in Dimension Unit
  height              Float?          // AG: Height in Dimension Unit
  diameter            Float?          // AH: Diameter for round products
  dimensionUnit       String?         // AI: cm, mm, inch (defaults to cm)

  // ── Logistics Group (AJ–AL) ──
  countryOfOrigin     String?         // AJ: Country (ISO 3166, controlled list)
  unit                String?         // AK: Unit of sale (PCS, PKT, CTN, ROLL, BUNDLE)
  minSalesMultiples   String?         // AL: Yes/No for minimum sales quantity

  // ── Commercial Group (AM) ──
  defaultPrice        Float?          // AM: Retail price in KWD (3 decimal places)

  // ── SEO Group (AN–AR) ──
  seoTitleEn          String?         // AN: SEO title English (< 60 chars)
  seoTitleAr          String?         // AO: SEO title Arabic (defaults to Name AR)
  seoDescriptionEn    String?         // AP: SEO meta description English
  seoDescriptionAr    String?         // AQ: SEO meta description Arabic
  searchKeywords      String?         // AR: Pipe-separated keywords

  // ── Internal Group (AS–AZ) ──
  internalNotes       String?         // AS: Internal staff notes
  validationStatus    String?         // AT: Validated, Pending Review, Draft, Rejected
  confidenceScore     Int?            // AU: 0–100 translation quality score
  pieces              Int?            // AV: Number of pieces in set
  setCount            Int?            // AW: Number of items in coordinated set
  shape               String?         // AX: Square, Round, Rectangular, Oval, Circular
  finish              String?         // AY: Coated, Chrome, Black Chrome, Polished, Matte, Powder-coated
  additionalInfo      String?         // AZ: Extra attributes (with Lid, Glass Lid, etc.)

  // ── Legacy fields (kept for backward compatibility) ──
  photo               String?         // Legacy — no longer used in API
  colours             String?         // Legacy — migrated to single-select 'color'
  materials           String?         // Legacy — migrated to single-select 'material'
  made                String?         // Legacy — migrated to 'countryOfOrigin'
  price               Float?          // Legacy — migrated to 'defaultPrice'
  pcs                 Int?            // Legacy — migrated to 'pieces'

  // ── System fields ──
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // ── Relations ──
  images              ProductImage[]
  original            ProductOriginal?
  variantMemberships  VariantMember[]

  @@map("products")
}

// ─────────────────────────────────────────────────────────────────
// CHANGE TRACKING: Original Imported Values
// Stores the baseline values from ERP import for comparison
// ─────────────────────────────────────────────────────────────────

model ProductOriginal {
  id                  String   @id @default(cuid())
  productId           String   @unique

  // ── Product Identity Group ──
  sourceRow           Int?
  origProductId       String?         // Original Product ID from ERP
  sku                 String?
  ndNumber            String?
  barcode             String?
  legacyCode          String?
  brand               String?
  brandAr             String?
  brandCode           String?
  model               String?

  // ── Classification Group ──
  department          String?
  category            String?
  subcategory         String?
  sectionCode         String?
  productFamily       String?
  productType         String?

  // ── Product Information Group ──
  nameAr              String?
  nameEn              String?
  shortDescAr         String?
  shortDescEn         String?
  longDescAr          String?
  longDescEn          String?

  // ── Attributes Group ──
  color               String?
  colorAr             String?
  material            String?
  materialAr          String?
  capacity            Float?
  capacityUnit        String?
  weight              Float?
  weightUnit          String?
  length              Float?
  width               Float?
  height              Float?
  diameter            Float?
  dimensionUnit       String?

  // ── Logistics Group ──
  countryOfOrigin     String?
  unit                String?
  minSalesMultiples   String?

  // ── Commercial Group ──
  defaultPrice        Float?

  // ── SEO Group ──
  seoTitleEn          String?
  seoTitleAr          String?
  seoDescriptionEn    String?
  seoDescriptionAr    String?
  searchKeywords      String?

  // ── Internal Group ──
  internalNotes       String?
  validationStatus    String?
  confidenceScore     Int?
  pieces              Int?
  setCount            Int?
  shape               String?
  finish              String?
  additionalInfo      String?

  // ── System fields ──
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // ── Relation ──
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_originals")
}

// ─────────────────────────────────────────────────────────────────
// PRODUCT IMAGES
// ─────────────────────────────────────────────────────────────────

model ProductImage {
  id           String   @id @default(cuid())
  productId    String
  imageUrl     String
  displayOrder Int      @default(0)
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ─────────────────────────────────────────────────────────────────
// PRODUCT VARIANTS SYSTEM
// Manual variant groups for products with multiple colors/options
// ─────────────────────────────────────────────────────────────────

model VariantGroup {
  id              String   @id @default(cuid())
  name            String?              // Optional name for the variant group
  primaryProductId String              // The main/primary product of this group
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  members         VariantMember[]

  @@index([primaryProductId])
  @@map("variant_groups")
}

model VariantMember {
  id              String   @id @default(cuid())
  variantGroupId  String
  productId       String              // The product that is a variant
  color           String?             // Variant-specific: Color EN
  colorAr         String?             // Variant-specific: Color AR
  variantImage    String?             // Variant-specific image URL
  variantNotes    String?             // Notes for this specific variant
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  variantGroup    VariantGroup @relation(fields: [variantGroupId], references: [id], onDelete: Cascade)
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([variantGroupId])
  @@index([productId])
  @@unique([variantGroupId, productId])  // Prevent duplicate membership
  @@map("variant_members")
}