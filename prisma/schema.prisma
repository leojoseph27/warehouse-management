generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

model Product {
  id                  String          @id @default(cuid())

  // ── Product Identity Group (A–J) ──
  sourceRow           Int?            // A: Auto-generated sequential row number
  productId           String?         // B: Globally unique ERP identifier (12 digits)
  sku                 String?         // C: Stock Keeping Unit (12 digits, usually = Product ID)
  ndNumber            String?         // D: Al-Nassim internal number (ND-XXXX format)
  barcode             String?         // E: EAN-13 / UPC-A barcode
  legacyCode          String?         // F: Legacy ERP code (deprecated)
  brand               String?         // G: Brand name EN (controlled list)
  brandAr             String?         // H: Brand name AR (auto-derived from Brand)
  brandCode           String?         // I: 3-digit brand code (auto-derived from Brand)
  model               String?         // J: Manufacturer model/variant code

  // ── Classification Group (K–P) ──
  department          String?         // K: Taxonomy level 1 (controlled list)
  category            String?         // L: Taxonomy level 2 (dependent on Department)
  subcategory         String?         // M: Taxonomy level 3 (dependent on Category)
  sectionCode         String?         // N: 3-digit retail section code (auto-derived from Dept)
  productFamily       String?         // O: Taxonomy level 4 (dependent on Subcategory)
  productType         String?         // P: Taxonomy level 5 (dependent on Product Family)

  // ── Product Information Group (Q–W) ──
  nameAr              String?         // Q: Full product name in Arabic
  enCatalog           String?         // R: English catalog name (third name, alongside Name AR and Name EN)
  nameEn              String?         // S: Full product name in English
  shortDescAr         String?         // T: Short description AR (defaults to Name AR)
  shortDescEn         String?         // U: Short description EN (defaults to Name EN)
  longDescAr          String?         // V: Long description AR (optional)
  longDescEn          String?         // W: Long description EN (auto-generated from Brand + Name EN)

  // ── Attributes Group (X–AJ) ──
  color               String?         // X: Color EN (controlled list, 15 values)
  colorAr             String?         // Y: Color AR (auto-derived from Color)
  material            String?         // Z: Material EN (controlled list, ~15 values)
  materialAr          String?         // AA: Material AR (auto-derived from Material)
  capacity            Float?          // AB: Numeric capacity/volume/weight
  capacityUnit        String?         // AC: L, ml, kg, g
  weight              Float?          // AD: Product weight (decimal)
  weightUnit          String?         // AE: kg, g
  length              Float?          // AF: Length in Dimension Unit
  width               Float?          // AG: Width in Dimension Unit
  height              Float?          // AH: Height in Dimension Unit
  diameter            Float?          // AI: Diameter for round products
  dimensionUnit       String?         // AJ: cm, mm, inch (defaults to cm)

  // ── Logistics Group (AK–AM) ──
  countryOfOrigin     String?         // AK: Country (ISO 3166, controlled list)
  unit                String?         // AL: Unit of sale (PCS, PKT, CTN, ROLL, BUNDLE)
  minSalesMultiples   String?         // AM: Yes/No for minimum sales quantity

  // ── Commercial Group (AN) ──
  defaultPrice        Float?          // AN: Retail price in KWD (3 decimal places)

  // ── SEO Group (AO–AS) ──
  seoTitleEn          String?         // AO: SEO title English (< 60 chars)
  seoTitleAr          String?         // AP: SEO title Arabic (defaults to Name AR)
  seoDescriptionEn    String?         // AQ: SEO meta description English
  seoDescriptionAr    String?         // AR: SEO meta description Arabic
  searchKeywords      String?         // AS: Pipe-separated keywords

  // ── Internal Group (AT–BA) ──
  internalNotes       String?         // AT: Internal staff notes
  validationStatus    String?         // AU: Validated, Pending Review, Draft, Rejected
  confidenceScore     Int?            // AV: 0–100 translation quality score
  pieces              Int?            // AW: Number of pieces in set
  setCount            Int?            // AX: Number of items in coordinated set
  shape               String?         // AY: Square, Round, Rectangular, Oval, Circular
  finish              String?         // AZ: Coated, Chrome, Black Chrome, Polished, Matte, Powder-coated
  additionalInfo      String?         // BA: Extra attributes (with Lid, Glass Lid, etc.)

  // ── Legacy fields (kept for backward compatibility) ──
  photo               String?         // Legacy — no longer used in API
  colours             String?         // Legacy — migrated to single-select 'color'
  materials           String?         // Legacy — migrated to single-select 'material'
  made                String?         // Legacy — migrated to 'countryOfOrigin'
  price               Float?          // Legacy — migrated to 'defaultPrice'
  pcs                 Int?            // Legacy — migrated to 'pieces'

  // ── System fields ──
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // ── Relations ──
  images              ProductImage[]
  original            ProductOriginal?
  variantMemberships  VariantMember[]

  // ── Indexes for common queries ──
  @@index([ndNumber])
  @@index([barcode])
  @@index([brand])
  @@index([department])
  @@index([category])
  @@index([productFamily])
  @@index([productType])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([defaultPrice])
  @@index([validationStatus])

  @@map("products")
}

// ─────────────────────────────────────────────────────────────────
// CHANGE TRACKING: Original Imported Values
// Stores the baseline values from ERP import for comparison
// ─────────────────────────────────────────────────────────────────

model ProductOriginal {
  id                  String   @id @default(cuid())
  productId           String   @unique

  // ── Product Identity Group ──
  sourceRow           Int?
  origProductId       String?         // Original Product ID from ERP
  sku                 String?
  ndNumber            String?
  barcode             String?
  legacyCode          String?
  brand               String?
  brandAr             String?
  brandCode           String?
  model               String?

  // ── Classification Group ──
  department          String?
  category            String?
  subcategory         String?
  sectionCode         String?
  productFamily       String?
  productType         String?

  // ── Product Information Group ──
  nameAr              String?
  enCatalog           String?
  nameEn              String?
  shortDescAr         String?
  shortDescEn         String?
  longDescAr          String?
  longDescEn          String?

  // ── Attributes Group ──
  color               String?
  colorAr             String?
  material            String?
  materialAr          String?
  capacity            Float?
  capacityUnit        String?
  weight              Float?
  weightUnit          String?
  length              Float?
  width               Float?
  height              Float?
  diameter            Float?
  dimensionUnit       String?

  // ── Logistics Group ──
  countryOfOrigin     String?
  unit                String?
  minSalesMultiples   String?

  // ── Commercial Group ──
  defaultPrice        Float?

  // ── SEO Group ──
  seoTitleEn          String?
  seoTitleAr          String?
  seoDescriptionEn    String?
  seoDescriptionAr    String?
  searchKeywords      String?

  // ── Internal Group ──
  internalNotes       String?
  validationStatus    String?
  confidenceScore     Int?
  pieces              Int?
  setCount            Int?
  shape               String?
  finish              String?
  additionalInfo      String?

  // ── System fields ──
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // ── Relation ──
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_originals")
}

// ─────────────────────────────────────────────────────────────────
// PRODUCT IMAGES
// ─────────────────────────────────────────────────────────────────

model ProductImage {
  id           String   @id @default(cuid())
  productId    String
  imageUrl     String
  displayOrder Int      @default(0)
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Google Drive storage fields (added when migrating from base64 to Drive)
  driveFileId  String?  // Google Drive file ID
  thumbnailUrl String?  // https://drive.google.com/thumbnail?id={FILE_ID}&sz=w1000
  filename     String?  // Original filename
  mimeType     String?  // image/jpeg, image/png, etc.
  fileSize     Int?     // File size in bytes
  // Note: drivePageUrl can be derived from driveFileId, so we don't store it.

  @@index([productId])
  @@map("product_images")
}

// ─────────────────────────────────────────────────────────────────
// PRODUCT VARIANTS SYSTEM
// Manual variant groups for products with multiple colors/options
// ─────────────────────────────────────────────────────────────────

model VariantGroup {
  id              String   @id @default(cuid())
  name            String?              // Optional name for the variant group
  primaryProductId String              // The main/primary product of this group
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  members         VariantMember[]

  @@index([primaryProductId])
  @@map("variant_groups")
}

model VariantMember {
  id              String   @id @default(cuid())
  variantGroupId  String
  productId       String              // The product that is a variant
  color           String?             // Variant-specific: Color EN
  colorAr         String?             // Variant-specific: Color AR
  variantImage    String?             // Variant-specific image URL
  variantNotes    String?             // Notes for this specific variant
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  variantGroup    VariantGroup @relation(fields: [variantGroupId], references: [id], onDelete: Cascade)
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([variantGroupId])
  @@index([productId])
  @@unique([variantGroupId, productId])  // Prevent duplicate membership
  @@map("variant_members")
}

// ─────────────────────────────────────────────────────────────────
// IMPORT JOB QUEUE
// Background processing for large Excel imports
// ─────────────────────────────────────────────────────────────────

model ImportJob {
  id              String   @id @default(cuid())
  status          String   @default("pending")  // pending, processing, completed, failed, cancelled
  fileName        String
  fileSize        Int?
  totalRows       Int      @default(0)
  processedRows   Int      @default(0)
  importedRows    Int      @default(0)
  errorRows       Int      @default(0)
  skippedRows     Int      @default(0)
  progress        Int      @default(0)  // 0-100 percentage
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?   // Text field for error messages
  errorDetails    String?   // JSON stringified array of {row, error}
  resultData      String?   // JSON stringified full result
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("import_jobs")
}

// ─────────────────────────────────────────────────────────────────
// EXPORT JOBS (Production-grade chunked pipeline)
//
// Storage policy:
//   - Neon stores: job metadata, progress, cursor, chunk metadata, logs.
//   - Google Drive stores: all product image binaries (never Neon).
//   - Final ZIP is built ONCE during the 'building_zip' stage and uploaded
//     to Vercel Blob (object storage). The download endpoint just streams
//     the pre-built ZIP from Blob — no rebuild, no image refetch.
//   - Blobs are auto-deleted after ZIP_RETENTION_HOURS (default 48h).
//     ExportJob + ExportLog rows are kept permanently for audit.
//
// Lifecycle:
//   created → processing (loading_products → downloading_images →
//             writing_excel → building_zip → saving_package) → completed
//   Any stage can transition to failed or cancelled.
// ─────────────────────────────────────────────────────────────────

model ExportJob {
  id                String    @id @default(cuid())
  // pending, created, processing, completed, failed, cancelled, expired
  status            String    @default("pending")
  // Human-readable current stage label, e.g. "Downloading images..."
  stage             String    @default("")
  // 0-100, derived from completed chunks / total chunks
  percentage        Int       @default(0)
  // excel-package | excel-embedded
  exportMode        String    @default("excel-package")
  // high | medium | low — controls Google Drive thumbnail size param
  quality           String    @default("high")
  // SR filter range (null = all products)
  srFrom            Int?
  srTo              Int?
  // Totals (set during 'created' stage after COUNT query)
  totalProducts     Int       @default(0)
  totalImages       Int       @default(0)
  // Progress counters
  processedProducts Int       @default(0)
  downloadedImages  Int       @default(0)
  failedImages      Int       @default(0)
  // Cursor: last sourceRow successfully committed. null = no chunks done yet.
  // Used for resume — the next /process call picks up from cursor+1.
  cursor            Int?
  // Number of chunks persisted so far (matches max(chunkNumber) on ExportChunk).
  chunkCount        Int       @default(0)
  // Number of chunks that failed and need retry.
  failedChunkCount  Int       @default(0)
  // Total chunk time accumulated so far (ms). Used for ETA calculation.
  elapsedMs         Int       @default(0)
  // Estimated download size in bytes (computed from image count × avg size).
  estimatedSizeBytes Int?
  // Actual size of the generated ZIP/Excel file in bytes (set when completed).
  fileSize          Int?
  // Vercel Blob URL where the completed ZIP is stored. Set during 'building_zip'
  // stage. Null until the ZIP is uploaded. After retention expires, this is
  // cleared (set to null) but the ExportJob row is kept for audit.
  blobUrl           String?
  // When the blob should be auto-deleted. Set to completedAt + ZIP_RETENTION_HOURS.
  // The cleanup cron checks this field and deletes expired blobs.
  blobExpiresAt     DateTime?
  // URL the frontend uses to download the result. Always /api/export/[id]/download.
  downloadUrl       String?
  errorMessage      String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  chunks            ExportChunk[]
  logs              ExportLog[]

  @@index([status])
  @@index([createdAt])
  @@index([cursor])
  @@index([blobExpiresAt])
  @@map("export_jobs")
}

// ─────────────────────────────────────────────────────────────────
// EXPORT CHUNKS (metadata only — no image binaries)
//
// One row per successfully processed product batch. Stores:
//   - chunkNumber (sequential, 1-based)
//   - firstSourceRow / lastSourceRow (for resumability and verification)
//   - productIds (JSON array — used to re-fetch for ZIP streaming)
//   - imageManifest (JSON array of {folder, filename, driveFileId, url})
//   - excelRowsJson (JSON of precomputed Excel row data — built once,
//     reused during ZIP assembly)
//   - timing metrics (dbMs, driveMs, etc.) for performance analysis
//
// On finalize, all chunks are loaded in order, Excel rows are concatenated,
// and images are streamed directly from Google Drive into the archiver —
// they never touch Neon.
// ─────────────────────────────────────────────────────────────────

model ExportChunk {
  id              String   @id @default(cuid())
  jobId           String
  // 1-based chunk number (chunk 1 = first N products, etc.)
  chunkNumber     Int
  // SR range covered by this chunk — for resumability audits
  firstSourceRow  Int?
  lastSourceRow   Int?
  // Status of this chunk: pending | completed | failed
  status          String   @default("pending")
  // Number of products in this chunk (typically = EXPORT_CHUNK_SIZE)
  productCount    Int      @default(0)
  // Number of images referenced by this chunk
  imageCount      Int      @default(0)
  // Number of images successfully downloaded during this chunk's processing
  // (used for progress display; final ZIP downloads again on demand)
  imagesDownloaded Int     @default(0)
  // JSON array of product IDs in this chunk — used by /download to re-fetch
  // product data for Excel assembly
  productIdsJson  String   @default("[]")
  // JSON array of { folder, filename, driveFileId, url, isPrimary } entries.
  // Used by /download to stream images from Drive into the ZIP.
  imageManifestJson String @default("[]")
  // JSON array of precomputed Excel row objects (one per product).
  // Precomputed during chunk processing so finalize is fast.
  excelRowsJson   String   @default("[]")
  // Timing metrics (milliseconds)
  dbMs            Int      @default(0)
  driveMs         Int      @default(0)
  excelMs         Int      @default(0)
  totalMs         Int      @default(0)
  // Memory snapshot at chunk completion (heapUsed in MB)
  memoryMb        Int      @default(0)
  errorMessage    String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  job             ExportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, chunkNumber])
  @@index([jobId, chunkNumber])
  @@index([jobId, status])
  @@map("export_chunks")
}

// ─────────────────────────────────────────────────────────────────
// EXPORT LOGS
//
// Append-only log entries for each export job. Used for:
//   - Inspecting failed exports after the fact
//   - Performance analysis (per-chunk timing)
//   - Debugging stuck jobs
//
// Levels: debug | info | warn | error
// ─────────────────────────────────────────────────────────────────

model ExportLog {
  id          String   @id @default(cuid())
  jobId       String
  timestamp   DateTime @default(now())
  level       String   @default("info")  // debug | info | warn | error
  // Short source identifier (e.g., "process", "download", "stage-created")
  source      String   @default("")
  message     String
  // Optional JSON context (chunk number, timings, error stack, etc.)
  contextJson String?

  job         ExportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, timestamp])
  @@index([jobId, level])
  @@map("export_logs")
}