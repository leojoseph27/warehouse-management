# Al-Nassim Master Catalog - Environment Variables
# Copy this file to .env.local and fill in your actual values

# Database Connection (Neon PostgreSQL)
# Get your connection string from Neon dashboard: https://neon.tech
DATABASE_URL=postgresql://your_user:your_password@your-host.neon.tech/your_database?sslmode=require

# Admin Authentication
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=your_secure_password_here

# Optional: Neon Connection Pool (recommended for production)
# Add to DATABASE_URL: &pgbouncer=true&connect_timeout=10